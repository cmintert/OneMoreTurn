{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "agent",
            "if": "Bash(git commit*)",
            "prompt": "A git commit was just made. Run `git show HEAD --stat` to see what files changed. Then read CLAUDE.md. If the commit introduces new CLI commands, new source modules or layers, architectural changes, or changes to design invariants — update CLAUDE.md to reflect those changes. Skip updating for bug fixes, test additions that don't add new modules, documentation-only changes, or refactors that don't change the architecture. Only edit CLAUDE.md if it is genuinely out of date.",
            "statusMessage": "Checking if CLAUDE.md needs updating...",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx markdownlint-cli2:*)",
      "Bash(find . -name .markdownlintrc* -o -name .mdlintrc* -o -name markdownlint.json)",
      "Bash(ls -la .markdownlint*)",
      "Bash(grep -n \"^.\\\\{101,\\\\}\" DESIGN.md)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(npx markdownlint-cli:*)",
      "Bash(git -C \"c:/Users/chris/VSCodeProjects/OneMoreTurn/OneMoreTurn\" remote -v)",
      "Bash(python -m venv .venv)",
      "Bash(.venv/Scripts/activate)",
      "Bash(pip install:*)",
      "Bash(.venv/Scripts/python -m pytest)",
      "Bash(.venv/Scripts/pip install:*)",
      "Bash(.venv/Scripts/python -m pytest tests/test_events.py -v)",
      "Bash(.venv/Scripts/python -m pytest tests/test_rng.py -v)",
      "Bash(.venv/Scripts/python -m pytest tests/test_components.py -v)",
      "Bash(.venv/Scripts/python -m pytest tests/test_entity.py -v)",
      "Bash(.venv/Scripts/python -m pytest tests/test_world.py -v)",
      "Bash(.venv/Scripts/python -m pytest tests/test_systems.py -v)",
      "Bash(.venv/Scripts/python -m pytest tests/test_containment.py -v)",
      "Bash(.venv/Scripts/python -m pytest tests/test_integration.py -v)",
      "Bash(.venv/Scripts/python -m pytest -v)",
      "Bash(.venv/Scripts/python -m pytest --tb=short)",
      "Bash(grep -E \"\\\\.md$|\\\\.txt$\")",
      "Bash(python -m pytest tests/test_serialization.py tests/test_migrations.py tests/test_persistence.py -v)",
      "Bash(python -m pytest --tb=short -q)",
      "Bash(python -m pytest tests/test_persistence.py -v --tb=short)",
      "Bash(python -m pytest tests/test_actions.py tests/test_turn.py -v --tb=short)",
      "Bash(python -m pytest tests/ --tb=short -q)",
      "Bash(python -m pytest --co -q)",
      "Bash(wc -l /c/Users/chris/VSCodeProjects/OneMoreTurn/OneMoreTurn/src/engine/*.py /c/Users/chris/VSCodeProjects/OneMoreTurn/OneMoreTurn/src/persistence/*.py /c/Users/chris/VSCodeProjects/OneMoreTurn/OneMoreTurn/src/cli/*.py)",
      "Bash(find src/game -type f -name *.py)",
      "Bash(find c:UserschrisVSCodeProjectsOneMoreTurnOneMoreTurn -name .github -o -name .gitlab-ci.yml -o -name Jenkinsfile -o -name .travis.yml -o -name *.yml -o -name *.yaml)",
      "Bash(wc -l \"c:\\\\Users\\\\chris\\\\VSCodeProjects\\\\OneMoreTurn\\\\OneMoreTurn/src/engine\"/*.py \"c:\\\\Users\\\\chris\\\\VSCodeProjects\\\\OneMoreTurn\\\\OneMoreTurn/src/game\"/*.py \"c:\\\\Users\\\\chris\\\\VSCodeProjects\\\\OneMoreTurn\\\\OneMoreTurn/src/persistence\"/*.py \"c:\\\\Users\\\\chris\\\\VSCodeProjects\\\\OneMoreTurn\\\\OneMoreTurn/src/cli\"/*.py)",
      "Bash(wc -l \"c:/Users/chris/VSCodeProjects/OneMoreTurn/OneMoreTurn/src/engine\"/*.py \"c:/Users/chris/VSCodeProjects/OneMoreTurn/OneMoreTurn/src/game\"/*.py \"c:/Users/chris/VSCodeProjects/OneMoreTurn/OneMoreTurn/src/persistence\"/*.py \"c:/Users/chris/VSCodeProjects/OneMoreTurn/OneMoreTurn/src/cli\"/*.py)"
    ]
  }
}
